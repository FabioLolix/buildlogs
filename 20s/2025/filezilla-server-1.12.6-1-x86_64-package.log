FZ_BUILD_IS_DIRTY=0; \
\
case "personal" in \
	official) \
		FZ_COMMIT_ID="official build";; \
	nightly) \
		FZ_COMMIT_ID="nightly build";; \
	*) \
		if test ! -d "../.."/.git; then \
			FZ_COMMIT_ID="built from tarball"; \
		else \
			FZ_COMMIT_ID=$(cd "../.." && git rev-parse --short HEAD 2>/dev/null); \
			FZ_BUILD_IS_DIRTY=$(cd "../.." && git diff --quiet 2>/dev/null && echo 0 || echo 1); \
			if test -z "$FZ_COMMIT_ID"; then \
				FZ_COMMIT_ID="unknown source"; \
			else \
				FZ_COMMIT_ID="commit $FZ_COMMIT_ID"; \
			fi; \
		fi;; \
esac; \
\
echo '#define FZ_COMMIT_ID "'"$FZ_COMMIT_ID"'"' > "build_info_gen.hpp.tmp"; \
echo "#define FZ_BUILD_IS_DIRTY $FZ_BUILD_IS_DIRTY" >> "build_info_gen.hpp.tmp"; \
echo "#define FZ_BUILD_DATE" $(date -u +'"%Y-%m-%d"') >> "build_info_gen.hpp.tmp"
if ! cmp "build_info_gen.hpp.tmp" "build_info_gen.hpp" 2>/dev/null; then \
	mv "build_info_gen.hpp.tmp" "build_info_gen.hpp"; \
fi
make  install-recursive
